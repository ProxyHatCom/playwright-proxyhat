{
  "name": "playwright-proxyhat",
  "version": "0.1.0",
  "description": "Route Playwright browsers through ProxyHat residential proxies — a pinned sticky IP per browser context, geo-targeting, and rotating IPs.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ProxyHatCom/playwright-proxyhat.git"
  },
  "homepage": "https://github.com/ProxyHatCom/playwright-proxyhat#readme",
  "bugs": {
    "url": "https://github.com/ProxyHatCom/playwright-proxyhat/issues"
  },
  "keywords": [
    "playwright",
    "proxyhat",
    "proxy",
    "residential-proxy",
    "proxy-rotation",
    "web-scraping",
    "browser-automation",
    "sticky-session"
  ],
  "author": "ProxyHat",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "proxyhat": "^0.2.0"
  },
  "peerDependencies": {
    "playwright": ">=1.30"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "playwright": "^1.49.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
